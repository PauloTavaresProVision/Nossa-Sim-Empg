# Copiar para .env e preencher. O ficheiro .env nunca deve ser commitado.
UCALL_APIKEY=colocar_aqui_a_chave_da_ucall

# URL pública do site (sem barra final), usada para construir o link do PDF
# da cotação enviado ao call center no field11. Ex.: https://simulador.dominio.ao
PUBLIC_BASE_URL=https://colocar.o.dominio.aqui

# Nome da rede Docker do nginx-proxy-manager (ver: docker network ls)
PROXY_NETWORK=nginx-proxy-manager_default
